{
  "name": "@fredsocial/homebridge-tplink-tapo",
  "displayName": "Homebridge TP-Link Tapo",
  "version": "0.1.1",
  "description": "Homebridge plugin for legacy TP-Link/Kasa and newer Tapo devices",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "tplink",
    "tp-link",
    "kasa",
    "tapo",
    "homeautomation",
    "automation",
    "home",
    "smarthome",
    "smartplug",
    "smartswitch",
    "smartbulb"
  ],
  "bugs": {
    "url": "https://github.com/fredsocial/homebridge-tplink-tapo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredsocial/homebridge-tplink-tapo.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT AND Apache-2.0",
  "main": "lib/index.js",
  "files": [
    "config.schema.json",
    "lib"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.source.json",
    "clean": "rimraf lib/ build/",
    "clean:debug": "rimraf $PWD/test/homebridge/persist && npm run clean:debug:acc",
    "clean:debug:acc": "rimraf $PWD/test/homebridge/accessories",
    "clean:debugsim": "rimraf $PWD/test/homebridge-simulator/persist && npm run clean:debugsim:acc",
    "clean:debugsim:acc": "rimraf $PWD/test/homebridge-simulator/accessories",
    "debug": "npm run build && npm run debug:only",
    "debug:only": "homebridge --debug --user-storage-path $PWD/test/homebridge --plugin-path .",
    "debugsim": "npm run build && npm run debugsim:only",
    "debugsim:only": "homebridge --debug --user-storage-path $PWD/test/homebridge-simulator --plugin-path .",
    "lint": "eslint --ignore-path .gitignore --ignore-pattern 'src/tapo/**' --ext .js,.ts . && tsc --noEmit --project tsconfig.source.json",
    "prepare": "npm run build",
    "release": "commit-and-tag-version --sign",
    "spellcheck": "cspell '{src,test}/**/*' *.md",
    "start": "homebridge --plugin-path .",
    "pretest": "npm run lint",
    "test": "npm run test:only",
    "test:only": "jest",
    "preversion": "npm test",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "fakegato-history": "^0.6.5",
    "lodash.castarray": "^4.4.0",
    "lodash.defaults": "^4.2.0",
    "semver": "^7.7.4",
    "tplink-smarthome-api": "~5.0.0",
    "utf8": "^3.0.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/lodash.castarray": "^4.4.9",
    "@types/lodash.defaults": "^4.2.9",
    "@types/node": "^20.19.37",
    "@types/semver": "^7.7.1",
    "@types/utf8": "^3.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "commit-and-tag-version": "^12.6.1",
    "cspell": "^9.7.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fs-extra": "^11.3.4",
    "hap-nodejs": "~0.14.1",
    "homebridge": "~1.11.2",
    "jest": "^29.7.0",
    "jest-chain": "^1.1.6",
    "node-persist": "0.0.12",
    "prettier": "3.8.1",
    "rewire": "^7.0.0",
    "tplink-smarthome-simulator": "^5.0.1",
    "ts-essentials": "^10.1.1",
    "ts-jest": "^29.1.2",
    "typescript": "~5.3.3"
  },
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0-beta.0",
    "node": ">=18"
  },
  "commit-and-tag-version": {
    "scripts": {
      "prerelease": "npm test"
    }
  }
}
